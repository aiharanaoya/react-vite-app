{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"hostRules": [
		{
			"matchHost": "npm.pkg.github.com",
			"hostType": "npm",
			"token": "{{ secrets.GITHUB_NPM_TOKEN }}"
		}
	],
	"lockFileMaintenance": {
		"enabled": true
	},
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		}
	],
	"minimumReleaseAge": "3 days"
}
