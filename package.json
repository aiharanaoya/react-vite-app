		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react-swc": "4.3.1",
		"happy-dom": "20.9.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.8"
